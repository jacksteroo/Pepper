# Database
POSTGRES_URL=postgresql+asyncpg://pepper:pepper@localhost:5432/pepper

# LLM — Anthropic (optional, for complex reasoning only — summaries only, never raw personal data)
ANTHROPIC_API_KEY=sk-ant-...

# Web search (Brave Search API — https://api.search.brave.com)
BRAVE_API_KEY=

# Routing / driving times (Google Maps Distance Matrix API)
GOOGLE_MAPS_API_KEY=

# LLM — Ollama (local, default for all personal data)
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_LOCAL_MODEL=hermes3:latest
DEFAULT_FRONTIER_MODEL=claude-sonnet-4-6
# For local deep reasoning (background agents), override with: DEFAULT_FRONTIER_MODEL=local/nous-hermes2:34b

# Telegram Bot Setup:
# 1. Message @BotFather on Telegram, use /newbot to create your bot
# 2. Copy the token here
# 3. Get your Telegram user ID from @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# Life context
LIFE_CONTEXT_PATH=docs/LIFE_CONTEXT.md
OWNER_NAME=Your Name

# Owner's timezone (IANA name — https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TIMEZONE=America/Los_Angeles

# Query depth (default: true — every message does full proactive fetch)
# Set to false to re-enable light/heavy classification and skip fetches on greetings/chit-chat
ALWAYS_HEAVY=true

# Morning brief schedule (24h, local time)
MORNING_BRIEF_HOUR=7
MORNING_BRIEF_MINUTE=0

# Weekly review (0=Monday, 6=Sunday)
WEEKLY_REVIEW_DAY=6
WEEKLY_REVIEW_HOUR=18

# Google Calendar (OAuth — credentials file, not an API key)
# Download from: https://console.cloud.google.com/apis/credentials
# Save to: ~/.config/pepper/google_credentials.json
# Then run: python subsystems/calendar/setup_auth.py

# Email accounts (Gmail + Yahoo)
# Gmail: uses the same google_credentials.json as calendar (enable Gmail API in your Cloud project)
# Yahoo: uses an app-specific password from https://login.yahoo.com/account/security/app-passwords
# Run: python subsystems/communications/setup_auth.py

# Slack (read-only bot token — https://api.slack.com/apps)
# Required OAuth scopes: channels:read, channels:history, groups:read, groups:history,
#                        im:read, im:history, search:read
# 1. Create app at https://api.slack.com/apps
# 2. Add scopes under "OAuth & Permissions"
# 3. Install app to workspace, copy "Bot User OAuth Token"
SLACK_BOT_TOKEN=xoxb-...

# ngrok (optional, for exposing Pepper via public URL e.g. for Telegram webhooks)
NGROK_AUTHTOKEN=

# API auth (UUID key required on all endpoints except /health)
API_KEY=

# System
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_FILE_PATH=logs/pepper.log
PORT=8000
MONTHLY_SPEND_LIMIT_USD=50
